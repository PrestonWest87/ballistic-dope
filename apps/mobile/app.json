{
  "expo": {
    "name": "Ballistic Dope",
    "slug": "ballistic-dope",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "scheme": "ballistic-dope",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    }
  },
  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.ballisticdope.app",
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false
    }
  },
  "android": {
    "adaptiveIcon": {
      "backgroundColor": "#1a1a2e"
    },
    "package": "com.ballisticdope.app"
  },
  "plugins": [
    "expo-router"
  ],
  "extra": {
    "eas": {
      "projectId": "5dbb1468-ac2b-4258-9330-21bad94b2d93"
    }
  }

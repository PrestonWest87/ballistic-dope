{
  "name": "ballistic-dope",
  "version": "1.0.0",
  "expo": {
    "name": "Ballistic Dope",
    "slug": "ballistic-dope",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ballisticdope.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.ballisticdope.app"
    }
  },
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "experimental": {
      "ios": {
        "devicePriority": ["iphone"]
      }
    }
  }
}
{
  "expo": {
    "name": "Ballistic Dope",
    "slug": "ballistic-dope",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "ballistic-dope",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ballisticdope.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f23"
      },
      "package": "com.ballisticdope.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
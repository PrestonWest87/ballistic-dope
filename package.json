{
  "name": "ballistic-dope",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx expo start",
    "build": "npx expo export",
    "prebuild": "npx expo prebuild",
    "android": "npx expo run:android",
    "start": "npx expo start"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "js-ballistics": "^2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "expo": {
    "name": "Ballistic Dope",
    "slug": "ballistic-dope",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ballisticdope.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.ballisticdope.app"
    },
    "plugins": [
      "expo-router"
    ]
  }
}